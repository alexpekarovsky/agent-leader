{
  "name": "strict-qa",
  "roles": {
    "manager": "codex",
    "product_manager": "codex",
    "scrum_master": "codex",
    "qa_lead": "codex"
  },
  "routing": {
    "backend": "claude_code",
    "frontend": "gemini",
    "qa": "codex",
    "default": "codex"
  },
  "decisions": {
    "architecture": {
      "mode": "consensus",
      "members": ["codex", "claude_code", "gemini"],
      "tie_breaker": "codex"
    }
  },
  "triggers": {
    "heartbeat_timeout_minutes": 5,
    "auto_validate_reports_on_submit": false,
    "auto_open_bug_on_validation_failure": true,
    "auto_requeue_on_offline": true,
    "unsupervised_stop_enabled": true,
    "stop_max_open_bugs": 2,
    "stop_max_open_blockers": 3,
    "stop_max_validation_failures_per_task": 1,
    "stop_on_integrity_mismatch": true,
    "stop_on_deploy_mismatch": true,
    "allow_cross_project_agents": false
  }
}
