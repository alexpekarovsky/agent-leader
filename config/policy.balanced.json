{
  "name": "balanced",
  "roles": {
    "manager": "codex",
    "product_manager": "codex",
    "scrum_master": "codex",
    "qa_lead": "codex"
  },
  "routing": {
    "backend": "claude_code",
    "frontend": "gemini",
    "qa": "codex",
    "default": "codex"
  },
  "decisions": {
    "architecture": {
      "mode": "consensus",
      "members": [
        "codex",
        "claude_code",
        "gemini"
      ],
      "tie_breaker": "codex"
    }
  },
  "triggers": {
    "heartbeat_timeout_minutes": 10,
    "auto_validate_reports_on_submit": true,
    "auto_open_bug_on_validation_failure": true,
    "auto_requeue_on_offline": true,
    "unsupervised_stop_enabled": false,
    "stop_max_open_bugs": 5,
    "stop_max_open_blockers": 8,
    "stop_max_validation_failures_per_task": 3,
    "stop_on_integrity_mismatch": true,
    "stop_on_deploy_mismatch": true,
    "allow_cross_project_agents": true,
    "review_gate_default": "required"
  }
}